# ─────────────────────────────────────────────────────────────────────────────
# AI Employee Vault — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Demo Mode (zero API cost) ──────────────────────────────────────────────────
# Set DEMO_MODE=true to run the full pipeline with NO Anthropic API calls.
# All Claude responses are replaced with realistic pre-built mock responses.
# Outputs are clearly labelled "[Demo Mode / Simulated Claude Response]".
# Perfect for hackathon demos, CI testing, and local development.
#
# To run the demo:  python demo/advanced_demo.py
# To run with API: set DEMO_MODE=false and provide ANTHROPIC_API_KEY below.
DEMO_MODE=true

# ── Anthropic / Claude ─────────────────────────────────────────────────────────
# Only required when DEMO_MODE=false
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6
MAX_TOKENS=8096

# ── Gmail Watcher ──────────────────────────────────────────────────────────────
# Enable IMAP in Gmail → Settings → Forwarding and POP/IMAP
# Use an App Password (not your account password):
#   Google Account → Security → 2-Step Verification → App Passwords
GMAIL_USER=your@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
GMAIL_POLL_INTERVAL=60

# ── WhatsApp Business API ─────────────────────────────────────────────────────
WHATSAPP_API_URL=https://graph.facebook.com/v18.0/YOUR_PHONE_NUMBER_ID
WHATSAPP_API_KEY=your_bearer_token_here

# ── Google Calendar ───────────────────────────────────────────────────────────
# Download OAuth2 credentials from Google Cloud Console
GOOGLE_CALENDAR_CREDENTIALS_PATH=credentials.json
GOOGLE_CALENDAR_ID=primary

# ── Filesystem Watcher ────────────────────────────────────────────────────────
WATCH_PATH=./watched_folder

# ── Filesystem MCP Output ────────────────────────────────────────────────────
FS_OUTPUT_DIR=./agent_outputs

# ── Orchestrator ──────────────────────────────────────────────────────────────
LOOP_INTERVAL=10
MAX_RETRIES=3

# ── Browser MCP ───────────────────────────────────────────────────────────────
# Set to false to use real Playwright browser (requires: pip install playwright && playwright install chromium)
BROWSER_DEMO=true

# ── SMTP (for email sending via email_mcp) ────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
